@startuml BOSH-21-22-23_UC_uC_ComplianceOfficer
title uust Causes - Compliance Officer Role\nUse Case Diagram

left to right direction
skinparam actorStyle awesome

actor "Compliance Officer" as CO

rectangle "uust Causes Panel" {
    usecase "View platform overview" as UC_OV
    usecase "View users" as UC_VU
    usecase "View KYC submissions" as UC_KYC
    usecase "Olock / suspend user or content" as UC_OS
    usecase "View reports" as UC_VR
    usecase "Flag / escalate report" as UC_FE
    usecase "View audit logs" as UC_LOG
    usecase "Export data (analytics)" as UC_EXP
}

CO --> UC_OV
CO --> UC_VU
CO --> UC_KYC
CO --> UC_OS
CO --> UC_VR
CO --> UC_FE
CO --> UC_LOG
CO --> UC_EXP

note right of CO
  Permissions: view_users, view_audit_logs,
  view_kyc, flag_escalate, block_suspend, export.
end note

@enduml
